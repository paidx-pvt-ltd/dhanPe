generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String
  firstName    String?
  lastName     String?
  phoneNumber  String?
  kycStatus    KYCStatus    @default(PENDING)
  balance      Decimal      @default(0) @db.Decimal(18, 2)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  isActive     Boolean      @default(true)

  transactions   Transaction[]
  ledgerEntries  Ledger[]
  refreshTokens  RefreshToken[]
  riskProfile    RiskProfile?
  idempotencyKeys IdempotencyKey[]

  @@index([email])
  @@index([createdAt])
}

model Transaction {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount          Decimal           @db.Decimal(18, 2)
  status          TransactionStatus @default(INITIATED)
  paymentProvider PaymentProvider   @default(CASHFREE)
  orderId         String            @unique
  providerOrderId String?
  paymentId       String?           @unique
  payoutStatus    PayoutStatus      @default(PENDING)
  bankAccount     Json
  description     String?
  idempotencyKey  String?           @unique
  metadata        Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  ledgerEntries Ledger[]
  payout        Payout?

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([payoutStatus, createdAt])
}

model Ledger {
  id           String          @id @default(cuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactionId String?
  transaction  Transaction?    @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  type         LedgerEntryType
  amount       Decimal         @db.Decimal(18, 2)
  referenceId  String
  balanceAfter Decimal         @db.Decimal(18, 2)
  createdAt    DateTime        @default(now())

  @@index([userId, createdAt])
  @@index([referenceId])
  @@index([transactionId])
}

model Payout {
  id            String       @id @default(cuid())
  txnId         String       @unique
  transaction   Transaction  @relation(fields: [txnId], references: [id], onDelete: Cascade)
  status        PayoutStatus @default(PENDING)
  bankAccount   Json
  providerRef   String?
  failureReason String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([status, createdAt])
}

model RiskProfile {
  userId         String    @id
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  riskScore      Int       @default(0)
  dailyLimitUsed Decimal   @default(0) @db.Decimal(18, 2)
  lastTxnAt      DateTime?
  lastTxnAmount  Decimal?  @db.Decimal(18, 2)
  velocityFlag   Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model WebhookEvent {
  id         String   @id @default(cuid())
  provider   String
  eventType  String
  eventId    String?  @unique
  orderId    String?
  payload    Json
  processed  Boolean  @default(false)
  error      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([provider, createdAt])
  @@index([orderId])
  @@index([processed, createdAt])
}

model IdempotencyKey {
  id          String   @id @default(cuid())
  key         String   @unique
  scope       String
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestHash String
  resourceId  String?
  responseBody Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([scope, createdAt])
  @@index([userId, scope])
}

enum KYCStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

enum TransactionStatus {
  INITIATED
  PAID
  FAILED
}

enum LedgerEntryType {
  DEBIT
  CREDIT
}

enum PayoutStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}

enum PaymentProvider {
  CASHFREE
}
