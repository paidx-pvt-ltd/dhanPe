# Convenience copy of the local development template.
# Preferred local workflow: copy this file or .env.development to .env.

NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dhanpe
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/dhanpe

JWT_SECRET=replace_with_a_long_random_dev_secret
JWT_EXPIRY=1h
JWT_REFRESH_SECRET=replace_with_a_second_long_random_dev_secret
JWT_REFRESH_EXPIRY=7d

CASHFREE_CLIENT_ID=your_cashfree_sandbox_client_id
CASHFREE_CLIENT_SECRET=your_cashfree_sandbox_client_secret
CASHFREE_PAYOUT_CLIENT_ID=your_cashfree_sandbox_payout_client_id
CASHFREE_PAYOUT_CLIENT_SECRET=your_cashfree_sandbox_payout_client_secret
CASHFREE_WEBHOOK_SECRET=your_cashfree_sandbox_webhook_secret
CASHFREE_API_BASE_URL=https://sandbox.cashfree.com
CASHFREE_PAYOUT_BASE_URL=https://payout-api.cashfree.com
CASHFREE_WEBHOOK_SIGNATURE_HEADER=x-webhook-signature
CASHFREE_WEBHOOK_TIMESTAMP_HEADER=x-webhook-timestamp

DIDIT_API_KEY=your_didit_api_key
DIDIT_WORKFLOW_ID=your_didit_workflow_id
DIDIT_WEBHOOK_SECRET=your_didit_webhook_secret
DIDIT_API_BASE_URL=https://verification.didit.me/v3

RISK_MAX_TRANSACTION_AMOUNT=50000
RISK_MAX_DAILY_VOLUME=100000
RISK_VELOCITY_WINDOW_MINUTES=10
RISK_VELOCITY_MAX_TRANSACTIONS=3

LOG_LEVEL=info
REDIS_URL=redis://127.0.0.1:6379
PAYOUT_QUEUE_CONCURRENCY=1
PAYOUT_QUEUE_POLL_INTERVAL_MS=15000
RECONCILIATION_ENABLED=true
RECONCILIATION_INTERVAL_MS=300000

SEED_USER_EMAIL=fintech-demo@example.com
SEED_USER_PASSWORD=SecurePassword123
